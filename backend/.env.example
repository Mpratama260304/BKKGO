# =============================================================================
# BKKGO backend environment template
# Copy to backend/.env and fill in real values for production.
# Never commit the real .env file.
# =============================================================================

PORT=4000

# Public origin used to build absolute short URLs (QR codes, emails, etc).
BASE_URL=http://localhost:4000

# Auth — JWT secret. MUST be a long random string in production.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-in-production-please

# Database — SQLite path
DB_PATH=./bkkgo.sqlite

# Seed credentials (used only on first run when the user does not yet exist)
ADMIN_EMAIL=bkkcemerlang@gmail.com
ADMIN_PASSWORD=#BKK_2026
SUPERADMIN_EMAIL=mpratamamail@gmail.com
SUPERADMIN_PASSWORD=Anonymous263

# Optional legacy single-provider reCAPTCHA fallback.
# Prefer configuring providers from the Admin → CAPTCHA UI instead.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# Optional: enable reverse-IP country lookup via free ip-api.com (no API key, ~45 req/min).
# Set to "1" to enable; leave empty for offline / privacy-sensitive deployments.
GEOIP_ENABLED=

# Optional: trust X-Forwarded-For from N hops (when behind a proxy / load balancer).
TRUST_PROXY=1
